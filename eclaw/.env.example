# eclaw 后端 - 环境变量模板
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 排除不会被提交

# === MySQL 数据库 ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=wclaw_db
DB_PASS=your_db_password
DB_NAME=wclaw_db

# === xCrab AI 端（必须配置）===
XCRAB_API_URL=http://127.0.0.1:60016
XCRAB_TOKEN=your_xcrab_token

# === JWT 签名密钥（必须配置，建议 32 位以上随机串）===
JWT_SECRET=your_jwt_secret_min_32_chars

# === 公网地址（用于构建文件下载链接）===
# 留空则使用 localhost
PUBLIC_HOST=localhost:10090

# === 短信网关（选填，未用可保持空）===
SMSBAO_USER=your_sms_user
SMSBAO_PASSWORD=your_sms_password

# === YOLO 推理服务（选填）===
YOLO_API_URL=http://127.0.0.1:60017

# === 服务端口 ===
PORT=10001
NODE_ENV=production
