# xCrab AI 端 - 环境变量模板
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 排除不会被提交

# === 网关配置 ===
GATEWAY_PORT=60016
# 鉴权 token，必须与 eclaw XCRAB_TOKEN 完全一致
GATEWAY_TOKEN=your_xcrab_token
# Gateway JWT 密钥
GATEWAY_JWT_SECRET=xcatch-gateway-secret

# === HuggingFace 镜像（国内推荐）===
HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_TELEMETRY=1

# === 工作目录 ===
WORKSPACE_DIR=./data/workspace-main
ACTIVE_WORKSPACE=main

# === 默认模型 ===
MODEL=MiniMax-M2.7

# === 模型 API Keys（按需填写）===
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MIMO_API_KEY=your_mimo_key
SENSENOVA_API_KEY=your_sensenova_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENROUTER_API_KEY=your_openrouter_key

# === 记忆系统 ===
ENABLE_MEMORY=false
MEMORY_AUTO_SUMMARY=true
# MEMORY_DB_PATH=./memory/memories.db

# === MCP 服务器配置（JSON 字符串）===
# MCP_SERVERS=[{"id":"example","command":"node","args":["server.js"]}]

# === 莞e租系统登录（如使用 auto_rental 系列脚本）===
GEZ_USERNAME=your_username
GEZ_PASSWORD=your_password
GEZ_PHONE=your_phone

# === 自定义 Hook 目录 ===
# HOOKS_DIR=./hooks
