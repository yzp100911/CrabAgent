# cclaw 代理端 - 环境变量模板
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 排除不会被提交

# === eclaw 后端连接 ===
# 本机部署默认 127.0.0.1:10001；远程服务器改为实际地址
ECLAW_API_URL=http://127.0.0.1:10001
ECLAW_WS_URL=ws://127.0.0.1:10001/ws

# === cclaw 本地服务 ===
# cclaw 监听的本地端口（仅本机）
LOCAL_API_PORT=10091

# === AI 后端类型 ===
# 可选: hermes / openai / custom
CCLAW_AI_BACKEND=hermes

# === 登录账号（首次启动自动创建）===
CCLAW_USERNAME=your_username
